# ── Auth / sessions / credential encryption ────────────────────
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ── Email sending: fallback operator account ────────────────────
# Used only for users who haven't connected their own Gmail below.
# Gmail App Password (default SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password

# OR use Resend instead (leave blank to use SMTP)
RESEND_API_KEY=

# ── Google OAuth (per-user Gmail sending — recommended) ────────
# Each user can connect their own Gmail instead of using the shared
# operator account above. Create an OAuth 2.0 Client ID ("Web application")
# in Google Cloud Console, add this redirect URI to it, add the gmail.send
# + userinfo.email scopes on the OAuth consent screen, and add each user's
# Google account as a "Test user" (avoids Google's app-verification process).
# Leave blank to disable — all alerts fall back to the operator account above.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# ── Telegram notifications (optional second alert channel) ────
# Create a bot via @BotFather on Telegram, paste its token + username here.
# Leave blank to disable Telegram entirely (email-only).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Scheduling ────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=15
ALERT_COOLDOWN_HOURS=12

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data.db

# Per-provider visa-site credentials (TLScontact/VFS/BLS) are no longer
# configured here — each user adds their own under "Provider Credentials"
# in the app, encrypted at rest using SECRET_KEY.

# ── AI agent scraper (browser-use + Claude) ────────────────────
# Required for any real (non-mock) scraper — the agent drives the browser.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_STEPS=30
AGENT_TIMEOUT_SECONDS=180

# ── Mock mode (set to true to use fake data for testing) ──────
USE_MOCK_SCRAPER=true
